@inherits LayoutComponentBase

<div class="oracle-shell">
    <aside class="oracle-nav">
        <div class="nav-brand">
            <div class="brand-sigil"></div>
            <div class="brand-text">
                <span class="brand-title">Spire Oracle</span>
                <span class="brand-sub">Analytics</span>
            </div>
        </div>

        <nav class="nav-links">
            <div class="nav-section-label">Dashboard</div>
            <NavLink class="nav-link" href="" Match="NavLinkMatch.All">
                <span class="nav-icon">&#x25C8;</span> Overview
            </NavLink>

            <div class="nav-section-label">Collection</div>
            <NavLink class="nav-link" href="cards">
                <span class="nav-icon">&#x2660;</span> Cards
            </NavLink>
            <NavLink class="nav-link" href="relics">
                <span class="nav-icon">&#x2666;</span> Relics
            </NavLink>
            <NavLink class="nav-link" href="elo">
                <span class="nav-icon">&#x2191;</span> Card Ratings
            </NavLink>
            <NavLink class="nav-link" href="cards/matchups">
                <span class="nav-icon">&#x2694;</span> Compare
            </NavLink>
            <NavLink class="nav-link" href="ancient-ratings">
                <span class="nav-icon">&#x2726;</span> Ancient
            </NavLink>

            <div class="nav-section-label">Runs</div>
            <NavLink class="nav-link" href="runs">
                <span class="nav-icon">&#x25B6;</span> History
            </NavLink>
            <NavLink class="nav-link" href="paths">
                <span class="nav-icon">&#x2637;</span> Pathing
            </NavLink>

            <div class="nav-section-label">Combat</div>
            <NavLink class="nav-link" href="combat">
                <span class="nav-icon">&#x2620;</span> Encounters
            </NavLink>
            <NavLink class="nav-link" href="economy">
                <span class="nav-icon">&#x25C9;</span> Economy
            </NavLink>
            <NavLink class="nav-link" href="rest-sites">
                <span class="nav-icon">&#x2668;</span> Rest Sites
            </NavLink>

            <div class="nav-section-label">Player</div>
            <NavLink class="nav-link" href="player-rating">
                <span class="nav-icon">&#x2605;</span> My Rating
            </NavLink>
            <NavLink class="nav-link" href="blind-spots">
                <span class="nav-icon">&#x25CE;</span> Blind Spots
            </NavLink>
        </nav>
    </aside>

    <main class="oracle-main">
        <RadzenComponents />
        <Sts2Analytics.Web.Components.GlobalFilter />
        @Body
    </main>
</div>
