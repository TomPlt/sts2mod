@page "/economy"
@inject DataService Data
@inject FilterState Filter
@implements IDisposable

<PageTitle>Economy - STS2 Analytics</PageTitle>

<h2>Economy</h2>

@if (_loading)
{
    <p><em>Loading...</em></p>
}
else
{
    @if (Filter.HasAnyFilter)
    {
        <div style="background: #2a2a3e; border: 1px solid #4fc3f7; border-radius: 6px; padding: 0.75rem 1rem; margin-bottom: 1rem; color: #4fc3f7; font-size: 0.85rem;">
            Note: Economy data is aggregated across all runs. Summary stats below are filtered.
        </div>
    }
    <div style="background: #1a1a2e; border-radius: 8px; padding: 1.5rem; border: 1px solid #2a2a4a; margin-bottom: 2rem;">
        <h3 style="margin: 0 0 1rem; color: #b0b0c8;">Gold Economy Overview</h3>
        <p style="color: #aaa; margin: 0;">
            Economy analytics track gold spending patterns across runs. As more data is collected,
            this page will show shop purchase breakdowns, gold efficiency metrics, and card removal impact analysis.
        </p>
    </div>

    <div style="display: flex; gap: 1.5rem; flex-wrap: wrap; margin-bottom: 2rem;">
        <div class="stat-card">
            <h3>@_totalRuns</h3>
            <p>Runs Tracked</p>
        </div>
        <div class="stat-card">
            <h3>@_winRate.ToString("P1")</h3>
            <p>Overall Win Rate</p>
        </div>
        <div class="stat-card">
            <h3>@_cardCount</h3>
            <p>Unique Cards Seen</p>
        </div>
        <div class="stat-card">
            <h3>@_relicCount</h3>
            <p>Unique Relics Seen</p>
        </div>
    </div>

    @if (_topRemovals.Count > 0)
    {
        <h3 style="color: #b0b0c8;">Top Cards by Pick Rate (Potential Shop Targets)</h3>
        <RadzenDataGrid Data="@_topRemovals" TItem="CardPickRate" AllowSorting="true" AllowPaging="true" PageSize="15"
                        Style="margin-bottom: 2rem;">
            <Columns>
                <RadzenDataGridColumn TItem="CardPickRate" Property="CardId" Title="Card" Width="200px">
                    <Template Context="c">@FormatName(c.CardId)</Template>
                </RadzenDataGridColumn>
                <RadzenDataGridColumn TItem="CardPickRate" Property="PickRate" Title="Pick Rate" FormatString="{0:P1}" Width="100px" />
                <RadzenDataGridColumn TItem="CardPickRate" Property="TimesOffered" Title="Offered" Width="80px" />
                <RadzenDataGridColumn TItem="CardPickRate" Property="TimesPicked" Title="Picked" Width="80px" />
            </Columns>
        </RadzenDataGrid>
    }
}

@code {
    private bool _loading = true;
    private int _totalRuns;
    private double _winRate;
    private int _cardCount;
    private int _relicCount;
    private List<CardPickRate> _topRemovals = [];
    private ExportData? _data;

    protected override async Task OnInitializedAsync()
    {
        _data = await Data.GetDataAsync();
        Filter.OnChange += OnFilterChanged;
        Recompute();
        _loading = false;
    }

    private void OnFilterChanged()
    {
        Recompute();
        InvokeAsync(StateHasChanged);
    }

    private void Recompute()
    {
        if (_data is null) return;

        var filteredRuns = _data.Runs.Where(Filter.MatchesRun).ToList();
        _totalRuns = filteredRuns.Count;
        _winRate = filteredRuns.Count > 0 ? (double)filteredRuns.Count(r => r.Win) / filteredRuns.Count : 0;
        _cardCount = _data.CardWinRates.Count;
        _relicCount = _data.RelicWinRates.Count;

        _topRemovals = _data.CardPickRates
            .OrderByDescending(c => c.PickRate)
            .Take(20)
            .ToList();
    }

    public void Dispose()
    {
        Filter.OnChange -= OnFilterChanged;
    }

    private static string FormatName(string id)
    {
        var dot = id.IndexOf('.');
        var name = dot >= 0 ? id[(dot + 1)..] : id;
        return name.Replace('_', ' ').ToLowerInvariant()
            .Split(' ')
            .Select(w => w.Length > 0 ? char.ToUpper(w[0]) + w[1..] : w)
            .Aggregate((a, b) => a + " " + b);
    }
}

<style>
    .stat-card {
        background: #1a1a2e;
        padding: 1.5rem;
        border-radius: 8px;
        text-align: center;
        flex: 1;
        min-width: 140px;
        border: 1px solid #2a2a4a;
    }

    .stat-card h3 {
        font-size: 2rem;
        margin: 0;
        color: #4fc3f7;
    }

    .stat-card p {
        margin: 0.5rem 0 0;
        color: #aaa;
    }
</style>
