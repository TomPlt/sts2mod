@page "/rest-sites"
@inject DataService Data
@inject FilterState Filter
@implements IDisposable

<PageTitle>Spire Oracle — Rest Sites</PageTitle>

@if (_loading)
{
    <p class="dim-text">Consulting the oracle...</p>
}
else
{
    <h2>Rest Site Analysis</h2>

    <div class="grid-2">
        <div class="panel">
            <h3>Decision Win Rates</h3>
            <p class="dim-text" style="font-size: 0.75rem; margin-bottom: 0.75rem;">
                Win rate of runs where you made each choice at a rest site.
            </p>
            <table class="oracle-table">
                <thead>
                    <tr>
                        <th>Choice</th>
                        <th style="text-align: right;">Count</th>
                        <th style="text-align: right;">Wins</th>
                        <th style="text-align: right;">Win Rate</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var d in _decisions)
                    {
                        <tr>
                            <td style="font-weight: 500;">@FormatChoice(d.Choice)</td>
                            <td style="text-align: right;" class="mono">@d.Count</td>
                            <td style="text-align: right;" class="mono">@d.Wins</td>
                            <td style="text-align: right;">
                                <span class="elo-badge @WinRateClass(d.WinRate)">@d.WinRate.ToString("P0")</span>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>

        <div class="panel">
            <h3>Decisions by Act</h3>
            <p class="dim-text" style="font-size: 0.75rem; margin-bottom: 0.75rem;">
                How your rest site choices change through the run.
            </p>
            @foreach (var actGroup in _actBreakdown.GroupBy(a => a.Act).OrderBy(g => g.Key))
            {
                <h4 class="act-label">Act @(actGroup.Key + 1)</h4>
                <table class="oracle-table" style="margin-bottom: 0.75rem;">
                    <thead>
                        <tr>
                            <th>Choice</th>
                            <th style="text-align: right;">Count</th>
                            <th style="text-align: right;">Win Rate</th>
                            <th style="text-align: right;">Avg HP%</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var row in actGroup.OrderByDescending(r => r.Count))
                        {
                            <tr>
                                <td style="font-weight: 500;">@FormatChoice(row.Choice)</td>
                                <td style="text-align: right;" class="mono">@row.Count</td>
                                <td style="text-align: right;">
                                    <span class="elo-badge @WinRateClass(row.WinRate)">@row.WinRate.ToString("P0")</span>
                                </td>
                                <td style="text-align: right;" class="mono">@row.AvgHpPercent.ToString("P0")</td>
                            </tr>
                        }
                    </tbody>
                </table>
            }
        </div>
    </div>

    <div class="panel" style="margin-bottom: var(--gap-lg);">
        <h3>Smith vs Heal Win Rate by HP%</h3>
        <p class="dim-text" style="font-size: 0.75rem; margin-bottom: 0.75rem;">
            When does upgrading outperform resting? Win rate comparison across health thresholds.
        </p>
        @if (_smithVsHealChart.Count > 0)
        {
            <RadzenChart Style="height: 260px;">
                <RadzenLineSeries Data="@_smithVsHealChart.Where(x => x.Choice == "Heal").ToList()"
                    CategoryProperty="HpRange" ValueProperty="WinRate" Title="Heal"
                    Stroke="#5bb8d4" StrokeWidth="2" />
                <RadzenLineSeries Data="@_smithVsHealChart.Where(x => x.Choice == "Smith").ToList()"
                    CategoryProperty="HpRange" ValueProperty="WinRate" Title="Smith"
                    Stroke="#f07040" StrokeWidth="2" />
                <RadzenCategoryAxis />
                <RadzenValueAxis Min="0" Max="1" FormatString="{0:P0}" />
                <RadzenLegend Position="LegendPosition.Bottom" />
            </RadzenChart>
        }
    </div>

    <div class="panel" style="margin-bottom: var(--gap-lg);">
        <h3>Smith vs Heal by HP%</h3>
        <p class="dim-text" style="font-size: 0.75rem; margin-bottom: 0.75rem;">
            Should you upgrade or rest? Win rate by HP threshold when making the decision.
        </p>
        <div class="hp-grid">
            @foreach (var bucket in _hpBuckets.GroupBy(b => new { b.HpBucketMin, b.HpBucketMax }).OrderBy(g => g.Key.HpBucketMin))
            {
                <div class="hp-bucket-card">
                    <div class="hp-bucket-label">@bucket.Key.HpBucketMin–@bucket.Key.HpBucketMax% HP</div>
                    @foreach (var row in bucket.OrderByDescending(r => r.Count))
                    {
                        <div class="hp-bucket-row">
                            <span class="choice-name">@FormatChoice(row.Choice)</span>
                            <span class="choice-count">@row.Count×</span>
                            <span class="elo-badge @WinRateClass(row.WinRate)">@row.WinRate.ToString("P0")</span>
                        </div>
                    }
                </div>
            }
        </div>
    </div>

    <div class="panel">
        <h3>Card Upgrade Impact</h3>
        <p class="dim-text" style="font-size: 0.75rem; margin-bottom: 0.75rem;">
            Which cards you upgrade at rest sites, and the run win rate when you do.
        </p>
        <table class="oracle-table">
            <thead>
                <tr>
                    <th style="width: 2rem">#</th>
                    <th>Card</th>
                    <th style="text-align: right;">Upgraded</th>
                    <th style="text-align: right;">Win Rate</th>
                </tr>
            </thead>
            <tbody>
                @{ var rank = 1; }
                @foreach (var u in _upgrades
                    .Where(u => u.TimesUpgraded >= 2)
                    .OrderByDescending(u => u.TimesUpgraded)
                    .ThenByDescending(u => u.WinRate)
                    .Take(20))
                {
                    <tr>
                        <td class="dim-text">@rank</td>
                        <td>@FormatName(u.CardId)</td>
                        <td style="text-align: right;" class="mono">@u.TimesUpgraded</td>
                        <td style="text-align: right;">
                            <span class="elo-badge @WinRateClass(u.WinRate)">@u.WinRate.ToString("P0")</span>
                        </td>
                    </tr>
                    rank++;
                }
            </tbody>
        </table>
    </div>
}

@code {
    private bool _loading = true;
    private ExportData? _data;
    private List<RestSiteDecisionExport> _decisions = [];
    private List<RestSiteHpBucketExport> _hpBuckets = [];
    private List<RestSiteUpgradeExport> _upgrades = [];
    private List<RestSiteActExport> _actBreakdown = [];
    private List<SmithVsHealPoint> _smithVsHealChart = [];

    record SmithVsHealPoint(string Choice, string HpRange, double WinRate);

    protected override async Task OnInitializedAsync()
    {
        _data = await Data.GetDataAsync();
        Filter.OnChange += OnFilterChanged;
        LoadData();
        _loading = false;
    }

    private void LoadData()
    {
        if (_data is null) return;
        _decisions = _data.RestSiteDecisions;
        _hpBuckets = _data.RestSiteHpBuckets;
        _upgrades = _data.RestSiteUpgrades;
        _actBreakdown = _data.RestSiteActBreakdown;

        // Build chart data from HP buckets
        var bucketLabels = new[] { (0, "0–25%"), (25, "25–50%"), (50, "50–75%"), (75, "75–100%") };
        var chartPoints = new List<SmithVsHealPoint>();
        foreach (var (min, label) in bucketLabels)
        {
            foreach (var choice in new[] { "SMITH", "HEAL" })
            {
                var bucket = _hpBuckets.FirstOrDefault(b => b.HpBucketMin == min && b.Choice == choice);
                if (bucket != null)
                    chartPoints.Add(new SmithVsHealPoint(FormatChoice(choice), label, bucket.WinRate));
            }
        }
        _smithVsHealChart = chartPoints;
    }

    private void OnFilterChanged()
    {
        InvokeAsync(StateHasChanged);
    }

    public void Dispose() => Filter.OnChange -= OnFilterChanged;

    static string WinRateClass(double wr) => wr switch
    {
        >= 0.6 => "high",
        >= 0.4 => "mid",
        _ => "low"
    };

    static string FormatChoice(string choice) =>
        string.Join(" ", choice.Split('_').Select(w =>
            w.Length > 0 ? char.ToUpper(w[0]) + w[1..].ToLower() : w));

    static string FormatName(string id)
    {
        var plusIdx = id.IndexOf('+');
        var suffix = "";
        var baseId = id;
        if (plusIdx >= 0) { suffix = " " + id[plusIdx..]; baseId = id[..plusIdx]; }
        var dot = baseId.IndexOf('.');
        var name = dot >= 0 ? baseId[(dot + 1)..] : baseId;
        return string.Join(" ", name.Split('_').Select(w =>
            w.Length > 0 ? char.ToUpper(w[0]) + w[1..].ToLower() : w)) + suffix;
    }
}

<style>
    .hp-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(220px, 1fr));
        gap: 1rem;
    }

    .hp-bucket-card {
        background: var(--void-2);
        border: 1px solid var(--surface-border);
        border-radius: 6px;
        padding: 1rem;
    }

    .hp-bucket-label {
        font-size: 0.85rem;
        font-weight: 600;
        color: var(--frost);
        margin-bottom: 0.5rem;
    }

    .hp-bucket-row {
        display: flex;
        align-items: center;
        gap: 0.5rem;
        padding: 0.2rem 0;
    }

    .choice-name {
        flex: 1;
        font-size: 0.85rem;
    }

    .choice-count {
        font-size: 0.75rem;
        color: var(--text-dim);
        font-family: 'JetBrains Mono', monospace;
    }

    .act-label {
        font-family: 'Cinzel', serif !important;
        font-size: 0.8rem !important;
        color: var(--frost) !important;
        text-transform: none !important;
        letter-spacing: 0.02em !important;
        margin: 0.75rem 0 0.25rem !important;
    }
</style>
