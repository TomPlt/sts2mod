@page "/combat"
@inject DataService Data
@inject FilterState Filter
@implements IDisposable

<PageTitle>Spire Oracle — Combat</PageTitle>

<h2>Combat</h2>

@if (_loading)
{
    <p class="dim-text">Consulting the oracle...</p>
}
else
{
    @if (Filter.HasAnyFilter)
    {
        <div class="filter-note">
            Note: Combat data is aggregated across all ascension levels. Character filter applies where available.
        </div>
    }

    <div class="combat-tabs">
        <button class="@(_tab == Tab.Pools ? "active" : "")" @onclick="() => SetTab(Tab.Pools)">Encounter Pools</button>
        <button class="@(_tab == Tab.Encounters ? "active" : "")" @onclick="() => SetTab(Tab.Encounters)">Enemy Ratings</button>
        <button class="@(_tab == Tab.Cards ? "active" : "")" @onclick="() => SetTab(Tab.Cards)">Card Combat Elo</button>
        <button class="@(_tab == Tab.Compare ? "active" : "")" @onclick="() => SetTab(Tab.Compare)">Pick vs Combat</button>
        <button class="@(_tab == Tab.Damage ? "active" : "")" @onclick="() => SetTab(Tab.Damage)">Damage Taken</button>
    </div>

    @if (_tab == Tab.Pools)
    {
        <p class="dim-text" style="margin-bottom: 0.75rem; font-size: 0.8rem;">
            How tough is each encounter pool? Higher rating = harder fights for your decks.
        </p>

        <div class="panel" style="padding: 0; overflow: hidden;">
            <table class="oracle-table elo-table">
                <thead>
                    <tr>
                        <th style="width: 3rem; text-align: center;">#</th>
                        <th>Pool</th>
                        <th style="width: 6rem; text-align: right;">Rating</th>
                        <th style="width: 3.5rem; text-align: right;">±</th>
                        <th style="width: 4rem; text-align: right;">Games</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var (row, i) in _poolRows.Select((r, i) => (r, i)))
                    {
                        <tr class="@(row.LowConfidence ? "low-confidence" : "")">
                            <td style="text-align: center;" class="dim-text mono">@(i + 1)</td>
                            <td style="font-weight: 500;">@row.Name</td>
                            <td style="text-align: right;">
                                <span class="elo-badge @GetRatingBadgeClass(row.Rating)">@row.Rating.ToString("F0")</span>
                            </td>
                            <td style="text-align: right;" class="dim-text mono">@row.Rd.ToString("F0")</td>
                            <td style="text-align: right;" class="dim-text mono">@row.Games</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }

    @if (_tab == Tab.Encounters)
    {
        <p class="dim-text" style="margin-bottom: 0.75rem; font-size: 0.8rem;">
            Per-encounter Glicko-2 ratings within their pool context. Higher = harder relative to decks at that stage.
        </p>

        <div class="act-filter">
            <input type="text" class="search-input" placeholder="Search encounters..." @bind="_searchText" @bind:event="oninput" @bind:after="ApplyEncounterFilter" />
            <span class="filter-divider"></span>
            <button class="@(_encContextFilter == null ? "active" : "")" @onclick="() => SetEncContext(null)">All</button>
            <button class="@(_encContextFilter == "act1" ? "active" : "")" @onclick='() => SetEncContext("act1")'>Act 1</button>
            <button class="@(_encContextFilter == "act2" ? "active" : "")" @onclick='() => SetEncContext("act2")'>Act 2</button>
            <button class="@(_encContextFilter == "act3" ? "active" : "")" @onclick='() => SetEncContext("act3")'>Act 3</button>
            <span class="filter-divider"></span>
            <button class="@(_encPoolFilter == null ? "active" : "")" @onclick="() => SetEncPoolFilter(null)">All</button>
            <button class="@(_encPoolFilter == "weak" ? "active" : "")" @onclick='() => SetEncPoolFilter("weak")'>Weak</button>
            <button class="@(_encPoolFilter == "normal" ? "active" : "")" @onclick='() => SetEncPoolFilter("normal")'>Normal</button>
            <button class="@(_encPoolFilter == "elite" ? "active" : "")" @onclick='() => SetEncPoolFilter("elite")'>Elite</button>
            <button class="@(_encPoolFilter == "boss" ? "active" : "")" @onclick='() => SetEncPoolFilter("boss")'>Boss</button>
        </div>

        <div class="panel" style="padding: 0; overflow: hidden;">
            <table class="oracle-table elo-table">
                <thead>
                    <tr>
                        <th style="width: 3rem; text-align: center;">#</th>
                        <th>Encounter</th>
                        <th style="width: 7rem;">Context</th>
                        <th style="width: 6rem; text-align: right;">Rating</th>
                        <th style="width: 3.5rem; text-align: right;">±</th>
                        <th style="width: 4rem; text-align: right;">Games</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var row in _filteredEncounterRows.Take(_showCount))
                    {
                        <tr class="@(row.LowConfidence ? "low-confidence" : "")">
                            <td style="text-align: center;" class="dim-text mono">@row.Rank</td>
                            <td style="font-weight: 500;">@row.Name</td>
                            <td class="dim-text" style="font-size: 0.8rem;">@row.Context</td>
                            <td style="text-align: right;">
                                <span class="elo-badge @GetRatingBadgeClass(row.Rating)">@row.Rating.ToString("F0")</span>
                            </td>
                            <td style="text-align: right;" class="dim-text mono">@row.Rd.ToString("F0")</td>
                            <td style="text-align: right;" class="dim-text mono">@row.Games</td>
                        </tr>
                    }
                </tbody>
            </table>

            @if (_filteredEncounterRows.Count > _showCount)
            {
                <div class="show-more" @onclick="ShowMore">
                    Show more (@(_filteredEncounterRows.Count - _showCount) remaining)
                </div>
            }
        </div>
    }

    @if (_tab == Tab.Cards)
    {
        <p class="dim-text" style="margin-bottom: 0.75rem; font-size: 0.8rem;">
            How well does each card perform in combat? Rated by deck-vs-pool Glicko-2 matchups.
        </p>

        <div class="act-filter">
            <input type="text" class="search-input" placeholder="Search cards..." @bind="_cardSearchText" @bind:event="oninput" @bind:after="ApplyCardFilter" />
        </div>

        <div class="panel" style="padding: 0; overflow: hidden;">
            <table class="oracle-table elo-table">
                <thead>
                    <tr>
                        <th style="width: 3rem; text-align: center;">#</th>
                        <th>Card</th>
                        <th style="width: 6rem; text-align: right;">Combat Elo</th>
                        <th style="width: 3.5rem; text-align: right;">±</th>
                        <th style="width: 4rem; text-align: right;">Games</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var row in _filteredCardRows.Take(_cardShowCount))
                    {
                        <tr class="@(row.LowConfidence ? "low-confidence" : "")">
                            <td style="text-align: center;" class="dim-text mono">@row.Rank</td>
                            <td style="font-weight: 500;">@row.Name</td>
                            <td style="text-align: right;">
                                <span class="elo-badge @GetRatingBadgeClass(row.Rating)">@row.Rating.ToString("F0")</span>
                            </td>
                            <td style="text-align: right;" class="dim-text mono">@row.Rd.ToString("F0")</td>
                            <td style="text-align: right;" class="dim-text mono">@row.Games</td>
                        </tr>
                    }
                </tbody>
            </table>

            @if (_filteredCardRows.Count > _cardShowCount)
            {
                <div class="show-more" @onclick="ShowMoreCards">
                    Show more (@(_filteredCardRows.Count - _cardShowCount) remaining)
                </div>
            }
        </div>
    }

    @if (_tab == Tab.Compare)
    {
        <p class="dim-text" style="margin-bottom: 0.75rem; font-size: 0.8rem;">
            Cards where pick/skip rating and combat performance diverge most. "Combat Fighter" = low pick Elo but great in combat. "Paper Tiger" = high pick Elo but weak in combat.
        </p>

        <div class="grid-2">
            <div class="panel">
                <h3 style="color: #4caf50; margin: 0 0 0.75rem 0; font-size: 1rem;">Combat Fighters</h3>
                <p class="dim-text" style="font-size: 0.75rem; margin-bottom: 0.5rem;">High combat Elo relative to pick Elo — undervalued in draft, strong in fights</p>
                <table class="oracle-table elo-table">
                    <thead>
                        <tr>
                            <th style="width: 3rem; text-align: center;">#</th>
                            <th>Card</th>
                            <th style="width: 5rem; text-align: right;">Pick</th>
                            <th style="width: 5rem; text-align: right;">Combat</th>
                            <th style="width: 4.5rem; text-align: right;">Gap</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var (row, i) in _combatFighters.Take(20).Select((r, i) => (r, i)))
                        {
                            <tr class="@(row.LowConfidence ? "low-confidence" : "")">
                                <td style="text-align: center;" class="dim-text mono">@(i + 1)</td>
                                <td style="font-weight: 500;">@row.Name</td>
                                <td style="text-align: right;">
                                    <span class="elo-badge @GetRatingBadgeClass(row.PickElo)">@row.PickElo.ToString("F0")</span>
                                </td>
                                <td style="text-align: right;">
                                    <span class="elo-badge @GetRatingBadgeClass(row.CombatElo)">@row.CombatElo.ToString("F0")</span>
                                </td>
                                <td style="text-align: right;">
                                    <span style="color: #4caf50; font-family: 'JetBrains Mono', monospace;">+@row.Gap.ToString("F0")</span>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>

            <div class="panel">
                <h3 style="color: #ef5350; margin: 0 0 0.75rem 0; font-size: 1rem;">Paper Tigers</h3>
                <p class="dim-text" style="font-size: 0.75rem; margin-bottom: 0.5rem;">High pick Elo relative to combat Elo — valued in draft, but weak in fights</p>
                <table class="oracle-table elo-table">
                    <thead>
                        <tr>
                            <th style="width: 3rem; text-align: center;">#</th>
                            <th>Card</th>
                            <th style="width: 5rem; text-align: right;">Pick</th>
                            <th style="width: 5rem; text-align: right;">Combat</th>
                            <th style="width: 4.5rem; text-align: right;">Gap</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var (row, i) in _paperTigers.Take(20).Select((r, i) => (r, i)))
                        {
                            <tr class="@(row.LowConfidence ? "low-confidence" : "")">
                                <td style="text-align: center;" class="dim-text mono">@(i + 1)</td>
                                <td style="font-weight: 500;">@row.Name</td>
                                <td style="text-align: right;">
                                    <span class="elo-badge @GetRatingBadgeClass(row.PickElo)">@row.PickElo.ToString("F0")</span>
                                </td>
                                <td style="text-align: right;">
                                    <span class="elo-badge @GetRatingBadgeClass(row.CombatElo)">@row.CombatElo.ToString("F0")</span>
                                </td>
                                <td style="text-align: right;">
                                    <span style="color: #ef5350; font-family: 'JetBrains Mono', monospace;">@row.Gap.ToString("F0")</span>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    }

    @if (_tab == Tab.Damage)
    {
        <h3 style="color: var(--text-secondary);">Damage by Encounter</h3>

        <RadzenDataGrid Data="@_damageRows" TItem="DamageRow" AllowSorting="true" AllowPaging="true" PageSize="25"
                        Style="margin-bottom: 2rem;">
            <Columns>
                <RadzenDataGridColumn TItem="DamageRow" Property="Name" Title="Encounter" Width="250px" />
                <RadzenDataGridColumn TItem="DamageRow" Property="AvgDamage" Title="Avg Damage" FormatString="{0:F1}" Width="120px"
                                      SortOrder="SortOrder.Descending" />
                <RadzenDataGridColumn TItem="DamageRow" Property="Fights" Title="Fights" Width="80px" />
            </Columns>
        </RadzenDataGrid>
    }
}

@code {
    private bool _loading = true;
    private Tab _tab = Tab.Pools;
    private string _searchText = "";
    private string _cardSearchText = "";
    private int _showCount = 40;
    private int _cardShowCount = 40;
    private string? _encContextFilter;
    private string? _encPoolFilter;

    enum Tab { Pools, Encounters, Cards, Compare, Damage }

    // Pool ratings
    private List<CombatRow> _poolRows = [];

    // Encounter ratings
    private List<CombatRow> _allEncounterRows = [];
    private List<CombatRow> _filteredEncounterRows = [];

    // Card combat ratings
    private List<CombatRow> _allCardRows = [];
    private List<CombatRow> _filteredCardRows = [];

    // Damage rows
    private List<DamageRow> _damageRows = [];

    // Comparison rows
    private List<CompareRow> _combatFighters = [];
    private List<CompareRow> _paperTigers = [];

    record CombatRow(int Rank, string Id, string Name, double Rating, double Rd, long Games, bool LowConfidence, string Context = "");
    record DamageRow(string Name, double AvgDamage, int Fights);
    record CompareRow(string CardId, string Name, double PickElo, double CombatElo, double Gap, bool LowConfidence);

    protected override async Task OnInitializedAsync()
    {
        var data = await Data.GetDataAsync();

        var charFilter = Filter.Character;

        // Pool ratings
        _poolRows = data.PoolRatings
            .Where(r => charFilter != null ? r.Character == charFilter : r.Character == "ALL")
            .Where(r => r.Context != "overall")
            .OrderByDescending(r => r.Rating)
            .Select((r, i) => new CombatRow(i + 1, r.CardId, FormatPoolName(r.Context), r.Rating, r.RatingDeviation, r.GamesPlayed, r.RatingDeviation > 200))
            .ToList();

        // Encounter ratings — use per-context (not overall) by default
        _allEncounterRows = data.GetEncounterRatings(Filter.Player)
            .Where(r => charFilter != null ? r.Character == charFilter : r.Character == "ALL")
            .Where(r => r.Context != "overall")
            .OrderByDescending(r => r.Rating)
            .Select((r, i) => new CombatRow(i + 1, r.CardId,
                FormatName(r.CardId.StartsWith("ENC.") ? r.CardId[4..] : r.CardId),
                r.Rating, r.RatingDeviation, r.GamesPlayed, r.RatingDeviation > 200,
                FormatPoolName(r.Context)))
            .ToList();
        ApplyEncounterFilter();

        // Card combat ratings
        _allCardRows = data.GetCombatRatings(Filter.Player)
            .Where(r => charFilter != null ? r.Character == charFilter : r.Character == "ALL")
            .Where(r => r.Context == "overall" && !r.CardId.StartsWith("POOL.") && !r.CardId.StartsWith("ENC."))
            .OrderByDescending(r => r.Rating)
            .Select((r, i) => new CombatRow(i + 1, r.CardId, FormatName(r.CardId), r.Rating, r.RatingDeviation, r.GamesPlayed, r.RatingDeviation > 200))
            .ToList();
        _filteredCardRows = _allCardRows;

        // Damage
        _damageRows = data.DamageByEncounter
            .OrderByDescending(d => d.AvgDamage)
            .Select(d => new DamageRow(FormatName(d.EncounterId), d.AvgDamage, d.SampleSize))
            .ToList();

        // Build comparison
        BuildComparison(data, charFilter);

        Filter.OnChange += OnFilterChanged;
        _loading = false;
    }

    private void SetTab(Tab tab) { _tab = tab; _showCount = 40; _cardShowCount = 40; }

    private void OnFilterChanged()
    {
        // Re-initialize with new filter
        _ = ReloadData();
    }

    private async Task ReloadData()
    {
        var data = await Data.GetDataAsync();
        var charFilter = Filter.Character;

        _poolRows = data.PoolRatings
            .Where(r => charFilter != null ? r.Character == charFilter : r.Character == "ALL")
            .Where(r => r.Context != "overall")
            .OrderByDescending(r => r.Rating)
            .Select((r, i) => new CombatRow(i + 1, r.CardId, FormatPoolName(r.Context), r.Rating, r.RatingDeviation, r.GamesPlayed, r.RatingDeviation > 200))
            .ToList();

        _allEncounterRows = data.GetEncounterRatings(Filter.Player)
            .Where(r => charFilter != null ? r.Character == charFilter : r.Character == "ALL")
            .Where(r => r.Context != "overall")
            .OrderByDescending(r => r.Rating)
            .Select((r, i) => new CombatRow(i + 1, r.CardId,
                FormatName(r.CardId.StartsWith("ENC.") ? r.CardId[4..] : r.CardId),
                r.Rating, r.RatingDeviation, r.GamesPlayed, r.RatingDeviation > 200,
                FormatPoolName(r.Context)))
            .ToList();
        ApplyEncounterFilter();

        _allCardRows = data.GetCombatRatings(Filter.Player)
            .Where(r => charFilter != null ? r.Character == charFilter : r.Character == "ALL")
            .Where(r => r.Context == "overall" && !r.CardId.StartsWith("POOL.") && !r.CardId.StartsWith("ENC."))
            .OrderByDescending(r => r.Rating)
            .Select((r, i) => new CombatRow(i + 1, r.CardId, FormatName(r.CardId), r.Rating, r.RatingDeviation, r.GamesPlayed, r.RatingDeviation > 200))
            .ToList();
        ApplyCardFilter();

        BuildComparison(data, charFilter);

        await InvokeAsync(StateHasChanged);
    }

    private void SetEncContext(string? ctx)
    {
        _encContextFilter = ctx;
        ApplyEncounterFilter();
    }

    private void SetEncPoolFilter(string? pool)
    {
        _encPoolFilter = pool;
        ApplyEncounterFilter();
    }

    private void ApplyEncounterFilter()
    {
        var filtered = _allEncounterRows.AsEnumerable();

        if (!string.IsNullOrEmpty(_searchText))
            filtered = filtered.Where(r => r.Name.Contains(_searchText, StringComparison.OrdinalIgnoreCase));

        if (_encContextFilter != null)
            filtered = filtered.Where(r => r.Context.StartsWith(_encContextFilter.Replace("act", "Act "), StringComparison.OrdinalIgnoreCase));

        if (_encPoolFilter != null)
            filtered = filtered.Where(r => r.Context.EndsWith(_encPoolFilter, StringComparison.OrdinalIgnoreCase));

        _filteredEncounterRows = filtered.ToList();
        for (var i = 0; i < _filteredEncounterRows.Count; i++)
            _filteredEncounterRows[i] = _filteredEncounterRows[i] with { Rank = i + 1 };
        _showCount = 40;
    }

    private void ApplyCardFilter()
    {
        _filteredCardRows = string.IsNullOrEmpty(_cardSearchText)
            ? _allCardRows
            : _allCardRows.Where(r => r.Name.Contains(_cardSearchText, StringComparison.OrdinalIgnoreCase)).ToList();
        for (var i = 0; i < _filteredCardRows.Count; i++)
            _filteredCardRows[i] = _filteredCardRows[i] with { Rank = i + 1 };
        _cardShowCount = 40;
    }

    private void ShowMore() => _showCount += 40;
    private void ShowMoreCards() => _cardShowCount += 40;

    private void BuildComparison(ExportData data, string? charFilter)
    {
        // Get pick/skip Elo (overall context)
        var pickContext = charFilter ?? "overall";
        var pickElos = data.Glicko2Ratings
            .Where(r => r.Context == pickContext && r.CardId != "SKIP")
            .ToDictionary(r => r.CardId, r => r);

        // Get combat Elo (overall context)
        var combatElos = data.GetCombatRatings(Filter.Player)
            .Where(r => (charFilter != null ? r.Character == charFilter : r.Character == "ALL")
                && r.Context == "overall"
                && !r.CardId.StartsWith("POOL.") && !r.CardId.StartsWith("ENC."))
            .ToDictionary(r => r.CardId, r => r);

        // Join on card ID, require both ratings with reasonable confidence
        var compared = pickElos.Keys
            .Intersect(combatElos.Keys)
            .Select(id =>
            {
                var pick = pickElos[id];
                var combat = combatElos[id];
                var gap = combat.Rating - pick.Rating;
                var lowConf = pick.RatingDeviation > 200 || combat.RatingDeviation > 200;
                return new CompareRow(id, FormatName(id), pick.Rating, combat.Rating, gap, lowConf);
            })
            .Where(r => !r.LowConfidence) // Only show confident comparisons
            .ToList();

        _combatFighters = compared.OrderByDescending(r => r.Gap).ToList();
        _paperTigers = compared.OrderBy(r => r.Gap).ToList();
    }

    public void Dispose()
    {
        Filter.OnChange -= OnFilterChanged;
    }

    private static string FormatPoolName(string context)
    {
        // "act1_boss" -> "Act 1 Boss"
        var parts = context.Split('_');
        if (parts.Length == 2)
        {
            var act = parts[0].Replace("act", "Act ");
            var pool = char.ToUpper(parts[1][0]) + parts[1][1..];
            return $"{act} {pool}";
        }
        return context;
    }

    private static string FormatName(string id)
    {
        // Strip prefixes like "ENC." or "ENCOUNTER."
        var dot = id.IndexOf('.');
        var name = dot >= 0 ? id[(dot + 1)..] : id;

        // Handle upgrade suffix
        var plusIdx = name.IndexOf('+');
        var suffix = "";
        if (plusIdx >= 0)
        {
            suffix = " " + name[plusIdx..];
            name = name[..plusIdx];
        }

        return string.Join(" ", name.Split('_').Select(w =>
            w.Length > 0 ? char.ToUpper(w[0]) + w[1..].ToLower() : w)) + suffix;
    }

    static string GetRatingBadgeClass(double rating) => rating switch
    {
        >= 1650 => "high",
        >= 1500 => "mid",
        _ => "low"
    };
}

<style>
    .combat-tabs {
        display: flex;
        gap: 0.5rem;
        margin-bottom: var(--gap-lg);
    }

    .combat-tabs button {
        background: var(--void-2);
        border: 1px solid var(--surface-border);
        border-radius: 4px;
        padding: 0.4rem 1rem;
        font-size: 0.8rem;
        color: var(--text-dim);
        cursor: pointer;
        transition: all 0.15s;
    }

    .combat-tabs button.active {
        background: rgba(212, 85, 42, 0.15);
        border-color: var(--ember);
        color: var(--ember-bright);
    }

    .combat-tabs button:hover:not(.active) {
        border-color: var(--text-dim);
        color: var(--text-primary);
    }

    .filter-note {
        font-size: 0.75rem;
        color: var(--frost);
        background: rgba(91, 184, 212, 0.06);
        border: 1px solid rgba(91, 184, 212, 0.12);
        border-radius: 4px;
        padding: 0.4rem 0.75rem;
        margin-bottom: var(--gap-md);
    }

    .act-filter {
        display: flex;
        gap: 0.5rem;
        margin-bottom: var(--gap-md);
        align-items: center;
    }

    .search-input {
        background: var(--void-2);
        border: 1px solid var(--surface-border);
        border-radius: 4px;
        padding: 0.35rem 0.6rem;
        font-size: 0.8rem;
        color: var(--text-primary);
        font-family: 'Outfit', sans-serif;
        width: 220px;
        outline: none;
        transition: border-color 0.15s;
    }
    .search-input:focus { border-color: var(--ember); }
    .search-input::placeholder { color: var(--text-dim); }

    .elo-table tbody td { font-size: 0.85rem; }
    .low-confidence td { opacity: 0.5; }

    .show-more {
        text-align: center;
        padding: 0.6rem;
        font-size: 0.75rem;
        color: var(--text-dim);
        cursor: pointer;
        border-top: 1px solid var(--surface-border);
        transition: color 0.15s;
    }
    .show-more:hover { color: var(--ember-bright); }
</style>
