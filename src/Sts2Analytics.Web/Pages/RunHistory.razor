@page "/runs"
@inject DataService Data
@inject FilterState Filter
@implements IDisposable

<PageTitle>Run History - STS2 Analytics</PageTitle>

<h2>Run History</h2>

@if (_loading)
{
    <p><em>Loading...</em></p>
}
else
{
    <RadzenDataGrid Data="@_filteredRuns" TItem="RunRow" AllowSorting="true" AllowPaging="true" PageSize="25"
                    Style="margin-bottom: 2rem;">
        <Columns>
            <RadzenDataGridColumn TItem="RunRow" Property="Character" Title="Character" Width="150px" />
            <RadzenDataGridColumn TItem="RunRow" Property="Ascension" Title="Asc" Width="60px" />
            <RadzenDataGridColumn TItem="RunRow" Property="Result" Title="Result" Width="80px">
                <Template Context="run">
                    <span style="color: @(run.Win ? "#66bb6a" : "#ef5350")">@run.Result</span>
                </Template>
            </RadzenDataGridColumn>
            <RadzenDataGridColumn TItem="RunRow" Property="Seed" Title="Seed" Width="140px" />
            <RadzenDataGridColumn TItem="RunRow" Property="GameMode" Title="Mode" Width="100px" />
        </Columns>
    </RadzenDataGrid>
}

@code {
    private bool _loading = true;
    private ExportData? _data;
    private List<RunRow> _filteredRuns = [];

    public record RunRow(string Character, int Ascension, bool Win, string Result, string Seed, string GameMode);

    protected override async Task OnInitializedAsync()
    {
        _data = await Data.GetDataAsync();
        Filter.OnChange += OnFilterChanged;
        ApplyFilter();
        _loading = false;
    }

    private void OnFilterChanged()
    {
        ApplyFilter();
        InvokeAsync(StateHasChanged);
    }

    private void ApplyFilter()
    {
        if (_data is null) return;

        _filteredRuns = _data.Runs
            .Where(Filter.MatchesRun)
            .OrderByDescending(r => r.Id)
            .Select(r => new RunRow(
                FormatName(r.Character),
                r.Ascension,
                r.Win,
                r.Win ? "Win" : "Loss",
                r.Seed,
                r.GameMode
            )).ToList();
    }

    public void Dispose()
    {
        Filter.OnChange -= OnFilterChanged;
    }

    private static string FormatName(string id)
    {
        var dot = id.IndexOf('.');
        var name = dot >= 0 ? id[(dot + 1)..] : id;
        return name.Replace('_', ' ').ToLowerInvariant()
            .Split(' ')
            .Select(w => w.Length > 0 ? char.ToUpper(w[0]) + w[1..] : w)
            .Aggregate((a, b) => a + " " + b);
    }
}
