@page "/elo"
@inject DataService Data

<PageTitle>Spire Oracle — Elo Rankings</PageTitle>

@if (_loading)
{
    <p class="dim-text">Consulting the oracle...</p>
}
else
{
    <h2>Elo Rankings</h2>

    <!-- Skip reference card -->
    @if (_skipRating != null)
    {
        <div class="skip-reference">
            <div class="skip-label">Skip Baseline</div>
            <div class="skip-elo mono">@_skipRating.Rating.ToString("F0")</div>
            <div class="skip-note">Cards above this line are worth picking. Cards below — skip.</div>
        </div>
    }

    <div style="margin-bottom: var(--gap-md); display: flex; gap: 1rem; align-items: center;">
        <RadzenDropDown @bind-Value="_selectedCharacter" Data="@_characters" Style="width: 200px;"
                        Placeholder="All Characters" AllowClear="true" Change="@(_ => ApplyFilter())" />
    </div>

    <div class="panel" style="padding: 0; overflow: hidden;">
        <table class="oracle-table elo-table">
            <thead>
                <tr>
                    <th style="width: 3rem; text-align: center;">#</th>
                    <th>Card</th>
                    <th style="width: 7rem; text-align: right;">Elo</th>
                    <th style="width: 4rem; text-align: right;">Games</th>
                    <th style="width: 12rem;">Rating</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var row in _filteredRatings.Take(_showCount))
                {
                    <tr class="@(row.CardId == "SKIP" ? "skip-highlight" : "")">
                        <td style="text-align: center;" class="dim-text mono">@row.Rank</td>
                        <td style="font-weight: 500;">@row.Name</td>
                        <td style="text-align: right;">
                            <span class="elo-badge @GetEloBadgeClass(row.Elo)">@row.Elo.ToString("F0")</span>
                        </td>
                        <td style="text-align: right;" class="dim-text mono">@row.Games</td>
                        <td>
                            <div class="elo-bar-track">
                                <div class="elo-bar-fill @(row.CardId == "SKIP" ? "skip" : "")"
                                     style="width: @(Math.Clamp((row.Elo - _minElo) / (_maxElo - _minElo) * 100, 2, 100))%"></div>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>

        @if (_filteredRatings.Count > _showCount)
        {
            <div class="show-more" @onclick="ShowMore">
                Show more (@(_filteredRatings.Count - _showCount) remaining)
            </div>
        }
    </div>
}

@code {
    private bool _loading = true;
    private ExportData? _data;
    private EloRatingResult? _skipRating;
    private string? _selectedCharacter;
    private List<string> _characters = [];
    private List<EloRow> _allRatings = [];
    private List<EloRow> _filteredRatings = [];
    private double _minElo = 1300;
    private double _maxElo = 1800;
    private int _showCount = 40;

    record EloRow(int Rank, string CardId, string Name, double Elo, long Games);

    protected override async Task OnInitializedAsync()
    {
        _data = await Data.GetDataAsync();

        _skipRating = _data.EloRatings
            .FirstOrDefault(e => e.CardId == "SKIP" && e.Context == "overall");

        _characters = _data.Runs
            .Select(r => r.Character)
            .Distinct()
            .OrderBy(c => c)
            .ToList();

        BuildRatings();
        _loading = false;
    }

    private void BuildRatings()
    {
        if (_data is null) return;
        var ratings = _data.EloRatings
            .Where(e => e.Context == "overall")
            .OrderByDescending(e => e.Rating)
            .ToList();

        _allRatings = ratings.Select((e, i) => new EloRow(
            i + 1, e.CardId, FormatName(e.CardId), e.Rating, e.GamesPlayed
        )).ToList();

        if (_allRatings.Count > 0)
        {
            _maxElo = _allRatings.Max(r => r.Elo);
            _minElo = _allRatings.Min(r => r.Elo);
        }

        ApplyFilter();
    }

    private void ApplyFilter()
    {
        if (string.IsNullOrEmpty(_selectedCharacter))
        {
            _filteredRatings = _allRatings;
        }
        else
        {
            // Switch to per-character context
            var charRatings = _data!.EloRatings
                .Where(e => e.Context == _selectedCharacter)
                .OrderByDescending(e => e.Rating)
                .Select((e, i) => new EloRow(i + 1, e.CardId, FormatName(e.CardId), e.Rating, e.GamesPlayed))
                .ToList();
            _filteredRatings = charRatings;

            if (charRatings.Count > 0)
            {
                _maxElo = charRatings.Max(r => r.Elo);
                _minElo = charRatings.Min(r => r.Elo);
            }
        }

        _showCount = 40;
    }

    private void ShowMore() => _showCount += 40;

    static string FormatName(string id)
    {
        var dot = id.IndexOf('.');
        var name = dot >= 0 ? id[(dot + 1)..] : id;
        return string.Join(" ", name.Split('_').Select(w =>
            w.Length > 0 ? char.ToUpper(w[0]) + w[1..].ToLower() : w));
    }

    static string GetEloBadgeClass(double rating) => rating switch
    {
        >= 1650 => "high",
        >= 1500 => "mid",
        _ => "low"
    };
}

<style>
    .skip-reference {
        background: rgba(212, 85, 42, 0.06);
        border: 1px solid rgba(212, 85, 42, 0.15);
        border-radius: 6px;
        padding: 0.75rem 1rem;
        margin-bottom: var(--gap-lg);
        display: flex;
        align-items: center;
        gap: 1rem;
    }

    .skip-label {
        font-family: 'Cinzel', serif;
        font-size: 0.8rem;
        color: var(--ember-bright);
        white-space: nowrap;
    }

    .skip-elo {
        font-size: 1.4rem;
        font-weight: 500;
        color: var(--ember-glow);
    }

    .skip-note {
        font-size: 0.75rem;
        color: var(--text-dim);
        flex: 1;
    }

    .elo-table tbody td { font-size: 0.85rem; }

    .elo-bar-track {
        height: 4px;
        background: var(--void-3);
        border-radius: 2px;
        overflow: hidden;
    }

    .elo-bar-fill {
        height: 100%;
        border-radius: 2px;
        background: linear-gradient(90deg, var(--frost-dim), var(--frost));
        transition: width 0.4s ease;
    }

    .elo-bar-fill.skip {
        background: linear-gradient(90deg, var(--ember-dim), var(--ember));
    }

    .show-more {
        text-align: center;
        padding: 0.6rem;
        font-size: 0.75rem;
        color: var(--text-dim);
        cursor: pointer;
        border-top: 1px solid var(--surface-border);
        transition: color 0.15s;
    }

    .show-more:hover {
        color: var(--ember-bright);
    }
</style>
