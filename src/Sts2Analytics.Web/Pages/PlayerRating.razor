@page "/player-rating"
@inject DataService Data
@inject FilterState Filter
@implements IDisposable

<PageTitle>Spire Oracle — My Rating</PageTitle>

@if (_loading)
{
    <p class="dim-text">Consulting the oracle...</p>
}
else
{
    <h2>My Rating</h2>
    <p class="dim-text" style="margin-top: -1.5rem; margin-bottom: 1.5rem; font-size: 0.85rem;">
        Your Glicko-2 player rating per character
    </p>

    <div class="stats-row" style="margin-bottom: var(--gap-lg);">
        @foreach (var r in _ratings)
        {
            <div class="stat-card @(r.Context == _selectedContext ? "selected" : "")"
                 style="cursor: pointer; text-align: center;"
                 @onclick="() => SelectContext(r.Context)">
                <div class="stat-label">@FormatContext(r.Context)</div>
                <div class="stat-value" style="color: var(--text-primary);">@r.Rating.ToString("F0")</div>
                <div class="dim-text" style="font-size: 0.7rem;">±@r.RatingDeviation.ToString("F0") RD · @r.GamesPlayed games</div>
            </div>
        }
    </div>

    <div class="panel">
        <h3>Recent Runs — @FormatContext(_selectedContext)</h3>
        <table class="oracle-table">
            <thead>
                <tr>
                    <th>Character</th>
                    <th>Opponent</th>
                    <th>Result</th>
                    <th style="text-align: right;">Rating Change</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var h in _history.Take(20))
                {
                    var change = h.RatingAfter - h.RatingBefore;
                    <tr>
                        <td><span class="char-tag @GetCharClass(h.Context)">@FormatContext(h.Context)</span></td>
                        <td class="mono">@h.Opponent</td>
                        <td>
                            <span class="result-pill @(h.Outcome > 0 ? "win" : "loss")">
                                @(h.Outcome > 0 ? "Win" : "Loss")
                            </span>
                        </td>
                        <td style="text-align: right;">
                            <span class="delta @(change >= 0 ? "positive" : "negative")">
                                @(change >= 0 ? "+" : "")@change.ToString("F0")
                            </span>
                            <span class="dim-text mono" style="font-size: 0.75rem;">
                                (@h.RatingBefore.ToString("F0") → @h.RatingAfter.ToString("F0"))
                            </span>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}

@code {
    private bool _loading = true;
    private List<PlayerRatingExport> _ratings = [];
    private List<PlayerRatingHistoryExport> _history = [];
    private string _selectedContext = "overall";
    private ExportData? _data;

    protected override async Task OnInitializedAsync()
    {
        _data = await Data.GetDataAsync();
        Filter.OnChange += OnFilterChanged;
        Recompute();
        _loading = false;
    }

    private void OnFilterChanged()
    {
        Recompute();
        InvokeAsync(StateHasChanged);
    }

    private void Recompute()
    {
        if (_data is null) return;

        var filteredRatings = _data.PlayerRatings.AsEnumerable();
        if (Filter.Character != null)
            filteredRatings = filteredRatings.Where(r => r.Context == Filter.Character || r.Context == "overall");

        _ratings = filteredRatings.OrderByDescending(r => r.Rating).ToList();
        UpdateHistory(_data);
    }

    private async Task SelectContext(string context)
    {
        _selectedContext = context;
        var data = await Data.GetDataAsync();
        UpdateHistory(data);
    }

    private void UpdateHistory(ExportData data)
    {
        _history = data.PlayerRatingHistory
            .Where(h => h.Context == _selectedContext)
            .OrderByDescending(h => h.RunId)
            .ToList();
    }

    public void Dispose()
    {
        Filter.OnChange -= OnFilterChanged;
    }

    private static string FormatContext(string context)
    {
        if (context == "overall") return "Overall";
        var name = context.Replace("CHARACTER.", "");
        return string.Join(" ", name.Split('_').Select(w =>
            w.Length > 0 ? char.ToUpper(w[0]) + w[1..].ToLower() : w));
    }

    static string GetCharClass(string id) => id.ToLower() switch
    {
        var s when s.Contains("ironclad") => "ironclad",
        var s when s.Contains("silent") => "silent",
        var s when s.Contains("defect") => "defect",
        var s when s.Contains("necrobinder") => "necrobinder",
        var s when s.Contains("regent") => "regent",
        _ => ""
    };
}

<style>
    .stat-card.selected {
        border-color: var(--ember);
        background: rgba(212, 85, 42, 0.06);
    }

    .stat-card.selected::after {
        background: linear-gradient(90deg, var(--ember), transparent);
    }
</style>
