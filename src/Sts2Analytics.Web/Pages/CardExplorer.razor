@page "/cards"
@inject DataService Data
@inject FilterState Filter
@implements IDisposable

<PageTitle>Card Explorer - STS2 Analytics</PageTitle>

<h2>Card Explorer</h2>

@if (_loading)
{
    <p><em>Loading...</em></p>
}
else
{
    <div style="margin-bottom: 1rem; display: flex; gap: 1rem; align-items: center;">
        <label>Min Games:</label>
        <RadzenNumeric @bind-Value="_minGames" Min="1" Max="100" Style="width: 80px;" Change="@((int _) => ApplyFilter())" />
    </div>

    <RadzenDataGrid Data="@_filteredCards" TItem="CardRow" AllowSorting="true" AllowPaging="true" PageSize="25"
                    Style="margin-bottom: 2rem;">
        <Columns>
            <RadzenDataGridColumn TItem="CardRow" Property="Name" Title="Card" Width="200px" />
            <RadzenDataGridColumn TItem="CardRow" Property="Elo" Title="Elo" FormatString="{0:F0}" Width="80px"
                                  SortOrder="SortOrder.Descending" />
            <RadzenDataGridColumn TItem="CardRow" Property="PickRate" Title="Pick%" FormatString="{0:P1}" Width="80px" />
            <RadzenDataGridColumn TItem="CardRow" Property="WinRatePicked" Title="Win%(picked)" FormatString="{0:P1}" Width="110px" />
            <RadzenDataGridColumn TItem="CardRow" Property="WinRateSkipped" Title="Win%(skipped)" FormatString="{0:P1}" Width="110px" />
            <RadzenDataGridColumn TItem="CardRow" Property="Delta" Title="Delta" FormatString="{0:+0.0%;-0.0%}" Width="80px" />
            <RadzenDataGridColumn TItem="CardRow" Property="Games" Title="Games" Width="70px" />
        </Columns>
    </RadzenDataGrid>
}

@code {
    private bool _loading = true;
    private ExportData? _data;
    private int _minGames = 3;
    private List<CardRow> _allCards = [];
    private List<CardRow> _filteredCards = [];

    public record CardRow(string Id, string Name, double Elo, double PickRate, double WinRatePicked, double WinRateSkipped, double Delta, long Games);

    protected override async Task OnInitializedAsync()
    {
        Filter.OnChange += OnFilterChanged;
        _data = await Data.GetDataAsync();
        Recompute();
        _loading = false;
    }

    private void Recompute()
    {
        if (_data is null) return;

        var (runIds, winMap) = ClientAnalytics.FilterRuns(_data.Runs, Filter);

        var winRates = _data.CardChoices.Count > 0
            ? ClientAnalytics.ComputeCardWinRates(_data.CardChoices, runIds, winMap).ToDictionary(c => c.CardId)
            : _data.CardWinRates.ToDictionary(c => c.CardId);

        var pickRates = _data.CardChoices.Count > 0
            ? ClientAnalytics.ComputeCardPickRates(_data.CardChoices, runIds).ToDictionary(c => c.CardId)
            : _data.CardPickRates.ToDictionary(c => c.CardId);

        var eloContext = Filter.Character ?? "overall";
        var eloLookup = _data.Glicko2Ratings
            .Where(e => e.Context == eloContext)
            .ToDictionary(e => e.CardId, e => e);

        var allCardIds = winRates.Keys.Union(pickRates.Keys).ToList();

        _allCards = allCardIds.Select(id =>
        {
            winRates.TryGetValue(id, out var cw);
            eloLookup.TryGetValue(id, out var elo);
            pickRates.TryGetValue(id, out var pick);
            return new CardRow(
                id,
                FormatName(id),
                elo?.Rating ?? 0,
                pick?.PickRate ?? 0,
                cw?.WinRateWhenPicked ?? 0,
                cw?.WinRateWhenSkipped ?? 0,
                cw?.WinRateDelta ?? 0,
                elo?.GamesPlayed ?? (cw != null ? cw.TimesPicked + cw.TimesSkipped : 0)
            );
        }).ToList();

        ApplyFilter();
    }

    private void ApplyFilter()
    {
        _filteredCards = _allCards.Where(c => c.Games >= _minGames).ToList();
    }

    public void Dispose()
    {
        Filter.OnChange -= OnFilterChanged;
    }

    private void OnFilterChanged()
    {
        Recompute();
        InvokeAsync(StateHasChanged);
    }

    private static string FormatName(string id)
    {
        var dot = id.IndexOf('.');
        var name = dot >= 0 ? id[(dot + 1)..] : id;
        return name.Replace('_', ' ').ToLowerInvariant()
            .Split(' ')
            .Select(w => w.Length > 0 ? char.ToUpper(w[0]) + w[1..] : w)
            .Aggregate((a, b) => a + " " + b);
    }
}

<style>
    .filter-note {
        font-size: 0.75rem;
        color: var(--text-dim);
        background: rgba(91, 184, 212, 0.06);
        border: 1px solid rgba(91, 184, 212, 0.12);
        border-radius: 4px;
        padding: 0.4rem 0.75rem;
        margin-bottom: var(--gap-md);
    }
</style>
