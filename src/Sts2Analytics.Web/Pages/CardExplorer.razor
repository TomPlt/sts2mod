@page "/cards"
@inject DataService Data
@inject FilterState Filter
@implements IDisposable

<PageTitle>Card Explorer - STS2 Analytics</PageTitle>

<h2>Card Explorer</h2>

@if (_loading)
{
    <p><em>Loading...</em></p>
}
else
{
    <div class="card-filter-bar">
        <div class="filter-group">
            <label>Min Games:</label>
            <RadzenNumeric @bind-Value="_minGames" Min="1" Max="100" Style="width: 80px;" Change="@((int _) => ApplyFilter())" />
        </div>
        <div class="upgrade-filter">
            <button class="@(_upgradeFilter == 0 ? "active" : "")" @onclick="() => SetUpgradeFilter(0)">All</button>
            <button class="@(_upgradeFilter == 1 ? "active" : "")" @onclick="() => SetUpgradeFilter(1)">Base</button>
            <button class="@(_upgradeFilter == 2 ? "active" : "")" @onclick="() => SetUpgradeFilter(2)">Upgraded</button>
        </div>
        <div class="upgrade-filter">
            <button class="@(_rarityFilter == null ? "active" : "")" @onclick="() => SetRarityFilter(null)">All</button>
            <button class="rarity-c @(_rarityFilter == "Common" ? "active" : "")" @onclick='() => SetRarityFilter("Common")'>C</button>
            <button class="rarity-u @(_rarityFilter == "Uncommon" ? "active" : "")" @onclick='() => SetRarityFilter("Uncommon")'>U</button>
            <button class="rarity-r @(_rarityFilter == "Rare" ? "active" : "")" @onclick='() => SetRarityFilter("Rare")'>R</button>
        </div>
    </div>

    <RadzenDataGrid Data="@_filteredCards" TItem="CardRow" AllowSorting="true" AllowPaging="true" PageSize="25"
                    Style="margin-bottom: 2rem;">
        <Columns>
            <RadzenDataGridColumn TItem="CardRow" Property="Name" Title="Card" Width="200px" />
            <RadzenDataGridColumn TItem="CardRow" Property="Elo" Title="Rating" FormatString="{0:F0}" Width="80px"
                                  SortOrder="SortOrder.Descending" />
            <RadzenDataGridColumn TItem="CardRow" Property="PickRate" Title="Pick%" FormatString="{0:P1}" Width="80px" />
            <RadzenDataGridColumn TItem="CardRow" Property="WinRatePicked" Title="Win%(picked)" FormatString="{0:P1}" Width="110px" />
            <RadzenDataGridColumn TItem="CardRow" Property="WinRateSkipped" Title="Win%(skipped)" FormatString="{0:P1}" Width="110px" />
            <RadzenDataGridColumn TItem="CardRow" Property="Delta" Title="Delta" FormatString="{0:+0.0%;-0.0%}" Width="80px" />
            <RadzenDataGridColumn TItem="CardRow" Property="Games" Title="Games" Width="70px" />
        </Columns>
    </RadzenDataGrid>
}

@code {
    private bool _loading = true;
    private ExportData? _data;
    private int _minGames = 3;
    private int _upgradeFilter; // 0=all, 1=base, 2=upgraded
    private string? _rarityFilter;
    private List<CardRow> _allCards = [];
    private List<CardRow> _filteredCards = [];

    public record CardRow(string Id, string Name, double Elo, double PickRate, double WinRatePicked, double WinRateSkipped, double Delta, long Games);

    protected override async Task OnInitializedAsync()
    {
        Filter.OnChange += OnFilterChanged;
        _data = await Data.GetDataAsync();
        await Data.GetCardRaritiesAsync();
        Recompute();
        _loading = false;
    }

    private void Recompute()
    {
        if (_data is null) return;

        var (runIds, winMap) = ClientAnalytics.FilterRuns(_data.Runs, Filter);

        var winRates = _data.CardChoices.Count > 0
            ? ClientAnalytics.ComputeCardWinRates(_data.CardChoices, runIds, winMap).ToDictionary(c => c.CardId)
            : _data.CardWinRates.ToDictionary(c => c.CardId);

        var pickRates = _data.CardChoices.Count > 0
            ? ClientAnalytics.ComputeCardPickRates(_data.CardChoices, runIds).ToDictionary(c => c.CardId)
            : _data.CardPickRates.ToDictionary(c => c.CardId);

        var eloContext = Filter.Character ?? "overall";
        var eloLookup = _data.Glicko2Ratings
            .Where(e => e.Context == eloContext)
            .ToDictionary(e => e.CardId, e => e);

        var allCardIds = winRates.Keys.Union(pickRates.Keys).ToList();

        _allCards = allCardIds.Select(id =>
        {
            winRates.TryGetValue(id, out var cw);
            eloLookup.TryGetValue(id, out var elo);
            pickRates.TryGetValue(id, out var pick);
            return new CardRow(
                id,
                FormatName(id),
                elo?.Rating ?? 0,
                pick?.PickRate ?? 0,
                cw?.WinRateWhenPicked ?? 0,
                cw?.WinRateWhenSkipped ?? 0,
                cw?.WinRateDelta ?? 0,
                elo?.GamesPlayed ?? (cw != null ? cw.TimesPicked + cw.TimesSkipped : 0)
            );
        }).ToList();

        ApplyFilter();
    }

    private void SetUpgradeFilter(int f)
    {
        _upgradeFilter = f;
        ApplyFilter();
    }

    private void SetRarityFilter(string? r)
    {
        _rarityFilter = r;
        ApplyFilter();
    }

    private void ApplyFilter()
    {
        _filteredCards = _allCards
            .Where(c => c.Games >= _minGames)
            .Where(c => _upgradeFilter switch
            {
                1 => !c.Id.Contains('+'),
                2 => c.Id.Contains('+'),
                _ => true
            })
            .Where(c => _rarityFilter == null || Data.GetRarity(c.Id) == _rarityFilter)
            .ToList();
    }

    public void Dispose()
    {
        Filter.OnChange -= OnFilterChanged;
    }

    private void OnFilterChanged()
    {
        Recompute();
        InvokeAsync(StateHasChanged);
    }

    private static string FormatName(string id)
    {
        var dot = id.IndexOf('.');
        var name = dot >= 0 ? id[(dot + 1)..] : id;
        return name.Replace('_', ' ').ToLowerInvariant()
            .Split(' ')
            .Select(w => w.Length > 0 ? char.ToUpper(w[0]) + w[1..] : w)
            .Aggregate((a, b) => a + " " + b);
    }
}

<style>
    .card-filter-bar {
        display: flex;
        align-items: center;
        gap: 1.5rem;
        margin-bottom: 1rem;
    }

    .filter-group {
        display: flex;
        align-items: center;
        gap: 0.5rem;
    }

    .upgrade-filter {
        display: flex;
        gap: 0.35rem;
    }

    .upgrade-filter button {
        background: var(--void-2);
        border: 1px solid var(--surface-border);
        border-radius: 4px;
        padding: 0.25rem 0.6rem;
        font-size: 0.75rem;
        color: var(--text-dim);
        cursor: pointer;
        transition: all 0.15s;
    }

    .upgrade-filter button.active {
        background: rgba(212, 85, 42, 0.15);
        border-color: var(--ember);
        color: var(--ember-bright);
    }

    .upgrade-filter button:hover:not(.active) {
        border-color: var(--text-dim);
        color: var(--text);
    }

    .upgrade-filter button.rarity-c.active {
        background: rgba(140, 170, 140, 0.2);
        border-color: #8caa8c;
        color: #8caa8c;
    }

    .upgrade-filter button.rarity-u.active {
        background: rgba(100, 160, 220, 0.2);
        border-color: #64a0dc;
        color: #64a0dc;
    }

    .upgrade-filter button.rarity-r.active {
        background: rgba(220, 180, 60, 0.2);
        border-color: #dcb43c;
        color: #dcb43c;
    }
</style>
