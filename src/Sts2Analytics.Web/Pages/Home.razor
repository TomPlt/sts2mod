@page "/"
@inject DataService Data

<PageTitle>STS2 Analytics</PageTitle>

<h2>Overview</h2>

@if (_data == null)
{
    <p>Loading...</p>
}
else
{
    <div class="stats-grid">
        <div class="stat-card">
            <h3>@_data.Summary?.TotalRuns</h3>
            <p>Total Runs</p>
        </div>
        <div class="stat-card">
            <h3>@_data.Summary?.Wins</h3>
            <p>Wins</p>
        </div>
        <div class="stat-card">
            <h3>@_data.Summary?.Losses</h3>
            <p>Losses</p>
        </div>
        <div class="stat-card">
            <h3>@(_data.Summary?.WinRate.ToString("P1"))</h3>
            <p>Win Rate</p>
        </div>
    </div>

    <div class="charts-row">
        <div class="chart-panel">
            <h3>Runs by Character</h3>
            <RadzenChart Style="height: 300px;">
                <RadzenPieSeries Data="@_characterData" CategoryProperty="Character" ValueProperty="Count" Title="Runs by Character" />
            </RadzenChart>
        </div>

        <div class="chart-panel">
            <h3>Elite Kills vs Win Rate</h3>
            <RadzenChart Style="height: 300px;">
                <RadzenBarSeries Data="@_eliteData" CategoryProperty="Label" ValueProperty="WinRate" Title="Win Rate" />
                <RadzenCategoryAxis />
                <RadzenValueAxis Min="0" Max="1" FormatString="{0:P0}" />
            </RadzenChart>
        </div>
    </div>

    <h3>Recent Runs</h3>
    <RadzenDataGrid Data="@_recentRuns" TItem="RunExport" AllowSorting="true" Style="margin-bottom: 2rem;">
        <Columns>
            <RadzenDataGridColumn TItem="RunExport" Property="Character" Title="Character" Width="200px">
                <Template Context="run">@FormatName(run.Character)</Template>
            </RadzenDataGridColumn>
            <RadzenDataGridColumn TItem="RunExport" Property="Ascension" Title="Asc" Width="60px" />
            <RadzenDataGridColumn TItem="RunExport" Property="Win" Title="Result" Width="80px">
                <Template Context="run">
                    <span style="color: @(run.Win ? "#66bb6a" : "#ef5350")">@(run.Win ? "Win" : "Loss")</span>
                </Template>
            </RadzenDataGridColumn>
            <RadzenDataGridColumn TItem="RunExport" Property="Seed" Title="Seed" Width="140px" />
            <RadzenDataGridColumn TItem="RunExport" Property="GameMode" Title="Mode" Width="100px" />
        </Columns>
    </RadzenDataGrid>

    <div class="charts-row">
        <div class="chart-panel">
            <h3>Top Card Win Rate Deltas</h3>
            <RadzenDataGrid Data="@_topCards" TItem="CardWinRate" AllowSorting="true" PageSize="10" AllowPaging="true" Style="margin-bottom: 1rem;">
                <Columns>
                    <RadzenDataGridColumn TItem="CardWinRate" Property="CardId" Title="Card" Width="200px">
                        <Template Context="c">@FormatName(c.CardId)</Template>
                    </RadzenDataGridColumn>
                    <RadzenDataGridColumn TItem="CardWinRate" Property="WinRateDelta" Title="Delta" FormatString="{0:+0.0%;-0.0%}" Width="80px" />
                    <RadzenDataGridColumn TItem="CardWinRate" Property="TimesPicked" Title="Picked" Width="70px" />
                </Columns>
            </RadzenDataGrid>
        </div>

        <div class="chart-panel">
            <h3>Top Elo Ratings</h3>
            <RadzenDataGrid Data="@_topElo" TItem="EloRatingResult" AllowSorting="true" PageSize="10" AllowPaging="true" Style="margin-bottom: 1rem;">
                <Columns>
                    <RadzenDataGridColumn TItem="EloRatingResult" Property="CardId" Title="Card" Width="200px">
                        <Template Context="e">@FormatName(e.CardId)</Template>
                    </RadzenDataGridColumn>
                    <RadzenDataGridColumn TItem="EloRatingResult" Property="Rating" Title="Rating" FormatString="{0:F0}" Width="80px" />
                    <RadzenDataGridColumn TItem="EloRatingResult" Property="GamesPlayed" Title="Games" Width="70px" />
                </Columns>
            </RadzenDataGrid>
        </div>
    </div>
}

@code {
    private ExportData? _data;
    private List<CharacterCount>? _characterData;
    private List<EliteWinRate>? _eliteData;
    private List<RunExport>? _recentRuns;
    private List<CardWinRate>? _topCards;
    private List<EloRatingResult>? _topElo;

    public record CharacterCount(string Character, int Count);
    public record EliteWinRate(string Label, double WinRate);

    protected override async Task OnInitializedAsync()
    {
        _data = await Data.GetDataAsync();

        _characterData = _data.Summary?.RunsByCharacter?
            .Select(kvp => new CharacterCount(FormatName(kvp.Key), kvp.Value))
            .ToList() ?? [];

        _eliteData = _data.EliteCorrelation
            .OrderBy(e => e.EliteCount)
            .Select(e => new EliteWinRate($"{e.EliteCount} elites", e.WinRate))
            .ToList();

        _recentRuns = _data.Runs
            .OrderByDescending(r => r.Id)
            .Take(20)
            .ToList();

        _topCards = _data.CardWinRates
            .Where(c => c.TimesPicked >= 3)
            .OrderByDescending(c => c.WinRateDelta)
            .Take(20)
            .ToList();

        _topElo = _data.EloRatings
            .OrderByDescending(e => e.Rating)
            .Take(20)
            .ToList();
    }

    private static string FormatName(string id)
    {
        // Strip prefix like "CHARACTER.", "CARD.", "RELIC."
        var dot = id.IndexOf('.');
        var name = dot >= 0 ? id[(dot + 1)..] : id;
        return name.Replace('_', ' ').ToLowerInvariant()
            .Split(' ')
            .Select(w => w.Length > 0 ? char.ToUpper(w[0]) + w[1..] : w)
            .Aggregate((a, b) => a + " " + b);
    }
}

<style>
    .stats-grid {
        display: flex;
        gap: 1rem;
        margin-bottom: 2rem;
        flex-wrap: wrap;
    }

    .stat-card {
        background: #1a1a2e;
        padding: 1.5rem;
        border-radius: 8px;
        text-align: center;
        flex: 1;
        min-width: 140px;
        border: 1px solid #2a2a4a;
    }

    .stat-card h3 {
        font-size: 2rem;
        margin: 0;
        color: #4fc3f7;
    }

    .stat-card p {
        margin: 0.5rem 0 0;
        color: #aaa;
    }

    .charts-row {
        display: flex;
        gap: 1.5rem;
        margin-bottom: 2rem;
        flex-wrap: wrap;
    }

    .chart-panel {
        flex: 1;
        min-width: 300px;
        background: #1a1a2e;
        border-radius: 8px;
        padding: 1rem;
        border: 1px solid #2a2a4a;
    }

    .chart-panel h3 {
        margin: 0 0 0.5rem;
        font-size: 1rem;
        color: #b0b0c8;
    }
</style>
