@page "/elo"
@inject DataService Data
@inject FilterState Filter
@implements IDisposable

<PageTitle>Spire Oracle — Card Ratings</PageTitle>

@if (_loading)
{
    <p class="dim-text">Consulting the oracle...</p>
}
else
{
    <h2>Card Ratings</h2>

    @if (_skipRating != null)
    {
        <div class="skip-reference">
            <div class="skip-label">Skip Baseline</div>
            <div class="skip-elo mono">@_skipRating.Rating.ToString("F0") <span class="skip-rd">±@_skipRating.Rd.ToString("F0")</span></div>
            <div class="skip-note">Cards above this line are worth picking. Cards below — skip.</div>
        </div>
    }

    <div class="act-filter">
        <input type="text" class="search-input" placeholder="Search cards..." @bind="_searchText" @bind:event="oninput" @bind:after="ApplyCardFilters" />
        <span class="filter-divider"></span>
        <button class="@(_actFilter == null ? "active" : "")" @onclick="() => SetActFilter(null)">All Acts</button>
        <button class="@(_actFilter == 1 ? "active" : "")" @onclick="() => SetActFilter(1)">Act 1</button>
        <button class="@(_actFilter == 2 ? "active" : "")" @onclick="() => SetActFilter(2)">Act 2</button>
        <button class="@(_actFilter == 3 ? "active" : "")" @onclick="() => SetActFilter(3)">Act 3</button>

        <span class="filter-divider"></span>

        <button class="@(_upgradeFilter == UpgradeFilter.All ? "active" : "")" @onclick="() => SetUpgradeFilter(UpgradeFilter.All)">All</button>
        <button class="@(_upgradeFilter == UpgradeFilter.BaseOnly ? "active" : "")" @onclick="() => SetUpgradeFilter(UpgradeFilter.BaseOnly)">Base</button>
        <button class="@(_upgradeFilter == UpgradeFilter.UpgradedOnly ? "active" : "")" @onclick="() => SetUpgradeFilter(UpgradeFilter.UpgradedOnly)">Upgraded</button>

        <span class="filter-divider"></span>

        <button class="@(_rarityFilter == null ? "active" : "")" @onclick="() => SetRarityFilter(null)">All</button>
        <button class="rarity-c @(_rarityFilter == "Common" ? "active" : "")" @onclick='() => SetRarityFilter("Common")'>C</button>
        <button class="rarity-u @(_rarityFilter == "Uncommon" ? "active" : "")" @onclick='() => SetRarityFilter("Uncommon")'>U</button>
        <button class="rarity-r @(_rarityFilter == "Rare" ? "active" : "")" @onclick='() => SetRarityFilter("Rare")'>R</button>
    </div>

    @if (_usingWinRateFallback)
    {
        <div class="filter-note">
            <span>Showing win-rate-delta ranking (Glicko-2 ratings are not computed per ascension). Score = 1500 + delta×500.</span>
        </div>
    }

    <div class="panel" style="padding: 0; overflow: hidden;">
        <table class="oracle-table elo-table">
            <thead>
                <tr>
                    <th style="width: 3rem; text-align: center;">#</th>
                    <th>Card</th>
                    <th style="width: 6rem; text-align: right;">Rating</th>
                    <th style="width: 3.5rem; text-align: right;">±</th>
                    @if (_actFilter == null && !_usingWinRateFallback)
                    {
                        <th style="width: 5rem; text-align: right;" class="act-col">Act 1</th>
                        <th style="width: 5rem; text-align: right;" class="act-col">Act 2</th>
                        <th style="width: 5rem; text-align: right;" class="act-col">Act 3</th>
                    }
                    <th style="width: 4rem; text-align: right;">Games</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var row in _filteredRatings.Take(_showCount))
                {
                    <tr class="@(row.CardId == "SKIP" ? "skip-highlight" : "") @(row.LowConfidence ? "low-confidence" : "")">
                        <td style="text-align: center;" class="dim-text mono">@row.Rank</td>
                        <td style="font-weight: 500;">@row.Name</td>
                        <td style="text-align: right;">
                            <span class="elo-badge @GetRatingBadgeClass(row.Rating)">@row.Rating.ToString("F0")</span>
                        </td>
                        <td style="text-align: right;" class="dim-text mono">@row.Rd.ToString("F0")</td>
                        @if (_actFilter == null && !_usingWinRateFallback)
                        {
                            <td style="text-align: right;">
                                @{ var a1 = GetActRatings(row.CardId).Act1; }
                                @if (a1 > 0)
                                {
                                    <span class="act-rating @GetActTrendClass(a1, row.Rating)">@a1.ToString("F0")</span>
                                }
                                else
                                {
                                    <span class="dim-text">—</span>
                                }
                            </td>
                            <td style="text-align: right;">
                                @{ var a2 = GetActRatings(row.CardId).Act2; }
                                @if (a2 > 0)
                                {
                                    <span class="act-rating @GetActTrendClass(a2, row.Rating)">@a2.ToString("F0")</span>
                                }
                                else
                                {
                                    <span class="dim-text">—</span>
                                }
                            </td>
                            <td style="text-align: right;">
                                @{ var a3 = GetActRatings(row.CardId).Act3; }
                                @if (a3 > 0)
                                {
                                    <span class="act-rating @GetActTrendClass(a3, row.Rating)">@a3.ToString("F0")</span>
                                }
                                else
                                {
                                    <span class="dim-text">—</span>
                                }
                            </td>
                        }
                        <td style="text-align: right;" class="dim-text mono">@row.Games</td>
                    </tr>
                }
            </tbody>
        </table>

        @if (_filteredRatings.Count > _showCount)
        {
            <div class="show-more" @onclick="ShowMore">
                Show more (@(_filteredRatings.Count - _showCount) remaining)
            </div>
        }
    </div>
}

@code {
    private bool _loading = true;
    private ExportData? _data;
    private RatingRow? _skipRating;
    private List<RatingRow> _allRatings = [];
    private List<RatingRow> _filteredRatings = [];
    private double _minRating = 1300;
    private double _maxRating = 1800;
    private int _showCount = 40;
    private int? _actFilter;
    private UpgradeFilter _upgradeFilter = UpgradeFilter.All;
    private string? _rarityFilter;
    private string _searchText = "";
    private bool _usingWinRateFallback;

    enum UpgradeFilter { All, BaseOnly, UpgradedOnly }

    // Per-act rating lookup: cardId -> (act1, act2, act3)
    private Dictionary<string, ActRatings> _actRatingLookup = new();

    record RatingRow(int Rank, string CardId, string Name, double Rating, double Rd, long Games, bool LowConfidence);
    record ActRatings(double Act1, double Act2, double Act3);

    protected override async Task OnInitializedAsync()
    {
        _data = await Data.GetDataAsync();
        await Data.GetCardRaritiesAsync();
        Filter.OnChange += OnFilterChanged;
        ApplyFilter();
        _loading = false;
    }

    private void OnFilterChanged()
    {
        ApplyFilter();
        InvokeAsync(StateHasChanged);
    }

    private void SetActFilter(int? act)
    {
        _actFilter = act;
        ApplyFilter();
    }

    private void SetUpgradeFilter(UpgradeFilter f)
    {
        _upgradeFilter = f;
        ApplyCardFilters();
    }

    private void SetRarityFilter(string? rarity)
    {
        _rarityFilter = rarity;
        ApplyCardFilters();
    }

    private static bool IsUpgraded(string cardId) => cardId.Contains('+');

    private void ApplyCardFilters()
    {
        var filtered = _allRatings.AsEnumerable();

        if (!string.IsNullOrEmpty(_searchText))
            filtered = filtered.Where(r => r.Name.Contains(_searchText, StringComparison.OrdinalIgnoreCase));

        filtered = _upgradeFilter switch
        {
            UpgradeFilter.BaseOnly => filtered.Where(r => !IsUpgraded(r.CardId)),
            UpgradeFilter.UpgradedOnly => filtered.Where(r => IsUpgraded(r.CardId)),
            _ => filtered
        };

        if (_rarityFilter != null)
            filtered = filtered.Where(r => Data.GetRarity(r.CardId) == _rarityFilter);

        _filteredRatings = filtered.ToList();

        // Re-rank after filtering
        for (var i = 0; i < _filteredRatings.Count; i++)
        {
            _filteredRatings[i] = _filteredRatings[i] with { Rank = i + 1 };
        }

        if (_filteredRatings.Count > 0)
        {
            _maxRating = _filteredRatings.Max(r => r.Rating);
            _minRating = _filteredRatings.Min(r => r.Rating);
        }

        _showCount = 40;
    }

    private void ApplyFilter()
    {
        if (_data is null) return;

        if (Filter.HasAscensionFilter && _data.CardChoices.Count > 0)
        {
            ApplyWinRateFallback();
            return;
        }

        _usingWinRateFallback = false;

        string context;
        if (_actFilter is not null && Filter.Character is not null)
            context = $"{Filter.Character}_ACT{_actFilter}";
        else if (Filter.Character is not null)
            context = Filter.Character;
        else
            context = "overall";

        List<Glicko2RatingResult> ratings;
        if (_actFilter is not null && Filter.Character is null)
        {
            // No per-character filter but act selected: aggregate across all character act contexts
            var actSuffix = $"_ACT{_actFilter}";
            ratings = _data.Glicko2Ratings
                .Where(e => e.Context.EndsWith(actSuffix))
                .GroupBy(e => e.CardId)
                .Select(g =>
                {
                    var totalGames = g.Sum(e => e.GamesPlayed);
                    var weightedRating = totalGames > 0
                        ? g.Sum(e => e.Rating * e.GamesPlayed) / totalGames
                        : g.Average(e => e.Rating);
                    var avgRd = totalGames > 0
                        ? g.Sum(e => e.RatingDeviation * e.GamesPlayed) / totalGames
                        : g.Average(e => e.RatingDeviation);
                    return new Glicko2RatingResult(g.Key, "ALL", $"overall{actSuffix}",
                        weightedRating, avgRd, 0, totalGames);
                })
                .OrderByDescending(e => e.Rating)
                .ToList();
        }
        else
        {
            ratings = _data.Glicko2Ratings
                .Where(e => e.Context == context)
                .OrderByDescending(e => e.Rating)
                .ToList();
        }

        _skipRating = ratings
            .Where(e => e.CardId == "SKIP")
            .Select(e => new RatingRow(0, e.CardId, "SKIP", e.Rating, e.RatingDeviation, e.GamesPlayed, e.RatingDeviation > 200))
            .FirstOrDefault();

        _allRatings = ratings.Select((e, i) => new RatingRow(
            i + 1, e.CardId, FormatName(e.CardId), e.Rating, e.RatingDeviation, e.GamesPlayed, e.RatingDeviation > 200
        )).ToList();

        if (_allRatings.Count > 0)
        {
            _maxRating = _allRatings.Max(r => r.Rating);
            _minRating = _allRatings.Min(r => r.Rating);
        }

        // Build per-act lookup
        BuildActRatingLookup();

        ApplyCardFilters();
    }

    private void BuildActRatingLookup()
    {
        if (_data is null) return;

        // Determine act context prefix based on character filter
        var charPrefix = Filter.Character ?? "";

        _actRatingLookup = _data.Glicko2Ratings
            .Where(e => e.Context.Contains("_ACT"))
            .Where(e => string.IsNullOrEmpty(charPrefix) || e.Context.StartsWith(charPrefix))
            .GroupBy(e => e.CardId)
            .ToDictionary(
                g => g.Key,
                g =>
                {
                    double a1 = 0, a2 = 0, a3 = 0;
                    foreach (var r in g)
                    {
                        if (r.Context.EndsWith("_ACT1")) a1 = Math.Max(a1, r.Rating);
                        else if (r.Context.EndsWith("_ACT2")) a2 = Math.Max(a2, r.Rating);
                        else if (r.Context.EndsWith("_ACT3")) a3 = Math.Max(a3, r.Rating);
                    }
                    return new ActRatings(a1, a2, a3);
                });
    }

    private ActRatings GetActRatings(string cardId) =>
        _actRatingLookup.GetValueOrDefault(cardId, new ActRatings(0, 0, 0));

    private void ApplyWinRateFallback()
    {
        _usingWinRateFallback = true;
        _actRatingLookup = new();
        var (runIds, winMap) = ClientAnalytics.FilterRuns(_data!.Runs, Filter);
        var winRates = ClientAnalytics.ComputeCardWinRates(_data.CardChoices, runIds, winMap);

        var sorted = winRates
            .Where(c => c.TimesPicked + c.TimesSkipped >= 3)
            .OrderByDescending(c => c.WinRateDelta)
            .ToList();

        _skipRating = null;
        _allRatings = sorted.Select((c, i) =>
        {
            var pseudoRating = 1500 + c.WinRateDelta * 500;
            var games = (long)(c.TimesPicked + c.TimesSkipped);
            return new RatingRow(i + 1, c.CardId, FormatName(c.CardId), pseudoRating, 0, games, games < 5);
        }).ToList();

        if (_allRatings.Count > 0)
        {
            _maxRating = _allRatings.Max(r => r.Rating);
            _minRating = _allRatings.Min(r => r.Rating);
        }

        ApplyCardFilters();
    }

    private void ShowMore() => _showCount += 40;

    public void Dispose()
    {
        Filter.OnChange -= OnFilterChanged;
    }

    static string FormatName(string id)
    {
        var plusIdx = id.IndexOf('+');
        var suffix = "";
        var baseId = id;
        if (plusIdx >= 0)
        {
            suffix = " " + id[plusIdx..];
            baseId = id[..plusIdx];
        }

        var dot = baseId.IndexOf('.');
        var name = dot >= 0 ? baseId[(dot + 1)..] : baseId;
        return string.Join(" ", name.Split('_').Select(w =>
            w.Length > 0 ? char.ToUpper(w[0]) + w[1..].ToLower() : w)) + suffix;
    }

    static string GetRatingBadgeClass(double rating) => rating switch
    {
        >= 1650 => "high",
        >= 1500 => "mid",
        _ => "low"
    };

    static string GetActTrendClass(double actRating, double overallRating)
    {
        var diff = actRating - overallRating;
        return diff switch
        {
            > 50 => "act-up",
            < -50 => "act-down",
            _ => "act-neutral"
        };
    }
}

<style>
    .skip-reference {
        background: rgba(212, 85, 42, 0.06);
        border: 1px solid rgba(212, 85, 42, 0.15);
        border-radius: 6px;
        padding: 0.75rem 1rem;
        margin-bottom: var(--gap-lg);
        display: flex;
        align-items: center;
        gap: 1rem;
    }

    .skip-label {
        font-family: 'Cinzel', serif;
        font-size: 0.8rem;
        color: var(--ember-bright);
        white-space: nowrap;
    }

    .skip-elo {
        font-size: 1.4rem;
        font-weight: 500;
        color: var(--ember-glow);
    }

    .skip-rd {
        font-size: 0.85rem;
        color: var(--text-dim);
    }

    .skip-note {
        font-size: 0.75rem;
        color: var(--text-dim);
        flex: 1;
    }

    .act-filter {
        display: flex;
        gap: 0.5rem;
        margin-bottom: var(--gap-md);
        align-items: center;
    }

    .search-input {
        background: var(--void-2);
        border: 1px solid var(--surface-border);
        border-radius: 4px;
        padding: 0.35rem 0.6rem;
        font-size: 0.8rem;
        color: var(--text-primary);
        font-family: 'Outfit', sans-serif;
        width: 180px;
        outline: none;
        transition: border-color 0.15s;
    }
    .search-input:focus { border-color: var(--ember); }
    .search-input::placeholder { color: var(--text-dim); }

    .act-filter button {
        background: var(--void-2);
        border: 1px solid var(--surface-border);
        border-radius: 4px;
        padding: 0.3rem 0.75rem;
        font-size: 0.75rem;
        color: var(--text-dim);
        cursor: pointer;
        transition: all 0.15s;
    }

    .act-filter button.active {
        background: rgba(212, 85, 42, 0.15);
        border-color: var(--ember);
        color: var(--ember-bright);
    }

    .act-filter button:hover:not(.active) {
        border-color: var(--text-dim);
        color: var(--text);
    }

    .filter-divider {
        width: 1px;
        height: 1.2rem;
        background: var(--surface-border);
        margin: 0 0.25rem;
    }

    .act-filter button.rarity-c.active {
        background: rgba(140, 170, 140, 0.2);
        border-color: #8caa8c;
        color: #8caa8c;
    }

    .act-filter button.rarity-u.active {
        background: rgba(100, 160, 220, 0.2);
        border-color: #64a0dc;
        color: #64a0dc;
    }

    .act-filter button.rarity-r.active {
        background: rgba(220, 180, 60, 0.2);
        border-color: #dcb43c;
        color: #dcb43c;
    }

    .elo-table tbody td { font-size: 0.85rem; }

    .low-confidence td { opacity: 0.5; }

    .act-col {
        font-size: 0.7rem;
        color: var(--text-dim);
    }

    .act-rating {
        font-family: 'JetBrains Mono', 'Fira Code', monospace;
        font-size: 0.8rem;
    }

    .act-up {
        color: #4caf50;
    }

    .act-down {
        color: #ef5350;
    }

    .act-neutral {
        color: var(--text-dim);
    }

    .elo-bar-track {
        height: 4px;
        background: var(--void-3);
        border-radius: 2px;
        overflow: hidden;
    }

    .elo-bar-fill {
        height: 100%;
        border-radius: 2px;
        background: linear-gradient(90deg, var(--frost-dim), var(--frost));
        transition: width 0.4s ease;
    }

    .elo-bar-fill.skip {
        background: linear-gradient(90deg, var(--ember-dim), var(--ember));
    }

    .elo-bar-fill.low-conf {
        opacity: 0.4;
    }

    .show-more {
        text-align: center;
        padding: 0.6rem;
        font-size: 0.75rem;
        color: var(--text-dim);
        cursor: pointer;
        border-top: 1px solid var(--surface-border);
        transition: color 0.15s;
    }

    .show-more:hover {
        color: var(--ember-bright);
    }

    .filter-note {
        font-size: 0.75rem;
        color: var(--text-dim);
        background: rgba(91, 184, 212, 0.06);
        border: 1px solid rgba(91, 184, 212, 0.12);
        border-radius: 4px;
        padding: 0.4rem 0.75rem;
        margin-bottom: var(--gap-md);
    }
</style>
