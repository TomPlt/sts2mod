@page "/relics"
@inject DataService Data
@inject FilterState Filter
@implements IDisposable

<PageTitle>Relic Explorer - STS2 Analytics</PageTitle>

<h2>Relic Explorer</h2>

@if (_loading)
{
    <p><em>Loading...</em></p>
}
else
{
    <RadzenDataGrid Data="@_relics" TItem="RelicRow" AllowSorting="true" AllowPaging="true" PageSize="25"
                    Style="margin-bottom: 2rem;">
        <Columns>
            <RadzenDataGridColumn TItem="RelicRow" Property="Name" Title="Relic" Width="200px" />
            <RadzenDataGridColumn TItem="RelicRow" Property="PickRate" Title="Pick%" FormatString="{0:P1}" Width="80px" />
            <RadzenDataGridColumn TItem="RelicRow" Property="WinRatePicked" Title="Win%(picked)" FormatString="{0:P1}" Width="110px" />
            <RadzenDataGridColumn TItem="RelicRow" Property="WinRateSkipped" Title="Win%(skipped)" FormatString="{0:P1}" Width="110px" />
            <RadzenDataGridColumn TItem="RelicRow" Property="Delta" Title="Delta" FormatString="{0:+0.0%;-0.0%}" Width="80px"
                                  SortOrder="SortOrder.Descending" />
            <RadzenDataGridColumn TItem="RelicRow" Property="TimesPicked" Title="Picked" Width="70px" />
        </Columns>
    </RadzenDataGrid>
}

@code {
    private bool _loading = true;
    private ExportData? _data;
    private List<RelicRow> _relics = [];

    public record RelicRow(string Name, double PickRate, double WinRatePicked, double WinRateSkipped, double Delta, int TimesPicked);

    protected override async Task OnInitializedAsync()
    {
        Filter.OnChange += OnFilterChanged;
        _data = await Data.GetDataAsync();
        Recompute();
        _loading = false;
    }

    private void Recompute()
    {
        if (_data is null) return;

        var (runIds, winMap) = ClientAnalytics.FilterRuns(_data.Runs, Filter);

        var winRates = _data.RelicChoices.Count > 0
            ? ClientAnalytics.ComputeRelicWinRates(_data.RelicChoices, runIds, winMap).ToDictionary(r => r.RelicId)
            : _data.RelicWinRates.ToDictionary(r => r.RelicId);

        var pickRates = _data.RelicChoices.Count > 0
            ? ClientAnalytics.ComputeRelicPickRates(_data.RelicChoices, runIds).ToDictionary(r => r.RelicId)
            : _data.RelicPickRates.ToDictionary(r => r.RelicId);

        var allIds = winRates.Keys.Union(pickRates.Keys).ToList();

        _relics = allIds.Select(id =>
        {
            winRates.TryGetValue(id, out var rw);
            pickRates.TryGetValue(id, out var pick);
            return new RelicRow(
                FormatName(id),
                pick?.PickRate ?? 0,
                rw?.WinRateWhenPicked ?? 0,
                rw?.WinRateWhenSkipped ?? 0,
                (rw?.WinRateWhenPicked ?? 0) - (rw?.WinRateWhenSkipped ?? 0),
                rw?.TimesPicked ?? 0
            );
        }).ToList();
    }

    public void Dispose()
    {
        Filter.OnChange -= OnFilterChanged;
    }

    private void OnFilterChanged()
    {
        Recompute();
        InvokeAsync(StateHasChanged);
    }

    private static string FormatName(string id)
    {
        var dot = id.IndexOf('.');
        var name = dot >= 0 ? id[(dot + 1)..] : id;
        return name.Replace('_', ' ').ToLowerInvariant()
            .Split(' ')
            .Select(w => w.Length > 0 ? char.ToUpper(w[0]) + w[1..] : w)
            .Aggregate((a, b) => a + " " + b);
    }
}

<style>
    .filter-note {
        font-size: 0.75rem;
        color: var(--text-dim);
        background: rgba(91, 184, 212, 0.06);
        border: 1px solid rgba(91, 184, 212, 0.12);
        border-radius: 4px;
        padding: 0.4rem 0.75rem;
        margin-bottom: var(--gap-md);
    }
</style>
